{
  "name": "simplesetup",
  "version": "0.1.1",
  "description": "Deploy open-source tools with one command. OpenClaw TUI and guided setup.",
  "bin": {
    "simplesetup": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "cli",
    "lib"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "tui": "tsx cli/index.ts",
    "tui:openclaw": "tsx cli/index.ts --tool openclaw",
    "build:cli": "node scripts/build-cli.js",
    "build:binaries": "npm run build:cli && pkg dist/package.json --out-path dist/bin"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "geist": "^1.7.0",
    "lucide-react": "^0.563.0",
    "motion": "^12.33.0",
    "neo-blessed": "^0.2.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/blessed": "^0.1.27",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@yao-pkg/pkg": "^6.4.0",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openclaw",
    "self-hosted",
    "cli",
    "tui",
    "deployment"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hridaya423/simplesetup.git"
  }
}
